---
// /ja/* → /* にリダイレクト（root locale = 日本語）
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  // root locale のエントリ（en/ を除く）を列挙
  const rootEntries = docs.filter((entry) => !entry.id.startsWith('en/'));
  return [
    // /ja/ → /
    { params: { slug: undefined } },
    // /ja/<slug> → /<slug>
    ...rootEntries.map((entry) => ({
      params: { slug: entry.slug },
    })),
  ];
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const slug = Astro.params.slug ?? '';
const target = slug ? `${base}/${slug}/` : `${base}/`;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>…</p>
    <script define:vars={{ target }}>window.location.replace(target);</script>
  </body>
</html>
